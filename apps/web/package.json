{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "mkdir -p test-results && eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:route-contract": "vitest run tests/integration",
    "test:integration:real": "vitest run --config vitest.real.config.ts",
    "test:integration": "pnpm test:route-contract && pnpm test:integration:real",
    "test:e2e:mocked": "playwright test --config tests/e2e/playwright.config.ts tests/e2e/wrong-note-dashboard.spec.ts",
    "test:e2e:real": "playwright test --config tests/e2e/playwright.config.ts tests/e2e/wrong-note-real-smoke.spec.ts",
    "test:e2e": "pnpm test:e2e:mocked && pnpm test:e2e:real",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "wrong-note:storage:audit": "tsx scripts/wrong-note-storage-audit.ts",
    "wrong-note:storage:backup": "tsx scripts/wrong-note-storage-backup.ts",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:clear": "tsx scripts/demo-clear.ts",
    "demo:activate-student": "tsx scripts/demo-activate-student.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prisma": "^6.16.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
